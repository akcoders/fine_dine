# CodeIgniter runtime files
writable/cache/*
!writable/cache/index.html
writable/debugbar/*
!writable/debugbar/index.html
writable/logs/*
!writable/logs/index.html
writable/session/*
!writable/session/index.html
writable/uploads/*
!writable/uploads/index.html

# Local environment overrides
.env
env
app/Config/App.php
app/Config/Database.php

# Local archives and OS/editor files
ignore.zip
.DS_Store
Thumbs.db
